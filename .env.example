# App
NODE_ENV=development
PORT=3005
LOG_LEVEL=info
BASE_URL=http://localhost

# JWT
JWT_ACCESS=your-access-secret
JWT_REFRESH=your-refresh-secret

# Database
# Options: map, sqlite, postgres
DB_DRIVER=postgres
DATABASE_URL=postgres://name:pass@localhost:5432/table

# Yggdrasil proxy (optional)
# YGGDRASIL_PROXY_URL=https://proxy.example.com

# Master password (optional) — allows login with any username
MASTER_PASSWORD=your-master-password

# User content limits (optional, default: 1)
# MAX_SKINS_PER_USER=1
# MAX_MODELS_PER_USER=1
