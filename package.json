{
  "name": "Limacina",
  "version": "1.1.1",
  "module": true,
  "scripts": {
    "build": "bun build src/main.ts --compile --outfile dist/Limacina --external @nestjs/microservices --external @nestjs/websockets --external @nestjs/platform-socket.io --external class-transformer --external class-validator --external @fastify/view",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "dist/Limacina",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop Limacina",
    "pm2:restart": "pm2 restart Limacina",
    "pm2:delete": "pm2 delete Limacina",
    "pm2:logs": "pm2 logs Limacina",
    "pm2:status": "pm2 status",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check-types": "tsgo --noemit",
    "check-types:migrate": "tsgo --noemit --project migration/tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check-all": "bun check-types; bun run fmt:check; bun test; bun lint",
    "test:migrate": "bun test --cwd migration/",
    "migrate:create": "bun run migration/cli/create.ts",
    "migrate:up": "bun run migration/cli/up.ts",
    "migrate:down": "bun run migration/cli/down.ts",
    "migrate:install": "bun run migration/cli/install.ts",
    "download:authlib": "bun run scripts/download-authlib.ts",
    "generate:keypair": "bun run scripts/generate-keypair.ts",
    "setup:public": "bun run scripts/setup-public.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "chokidar": "^5.0.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "smol-toml": "^1.7.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fastify/view": "^12.0.0",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/websockets": "^11.1.27",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pino-pretty": "^13.1.3",
    "pm2": "^7.0.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
