{
  "name": "Limacina",
  "version": "1.1.1",
  "module": true,
  "scripts": {
    "build": "nest build",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check-types": "tsgo --noemit",
    "check-types:migrate": "tsgo --noemit --project migration/tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check-all": "bun check-types; bun run fmt:check; bun test; bun lint",
    "test:migrate": "bun test --cwd migration/",
    "migrate:create": "bun run migration/cli/create.ts",
    "migrate:up": "bun run migration/cli/up.ts",
    "migrate:down": "bun run migration/cli/down.ts",
    "migrate:install": "bun run migration/cli/install.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "chokidar": "^4.0.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/testing": "^11.1.19",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
