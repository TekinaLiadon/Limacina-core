{
  "name": "Limacina",
  "version": "1.1.1",
  "module": true,
  "scripts": {
    "build": "nest build",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check-types": "tsgo --noemit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check-all": "bun check-types; bun run fmt:check; bun test"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "chokidar": "^4.0.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
